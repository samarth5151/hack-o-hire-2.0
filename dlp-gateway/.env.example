# ── Database (local Docker — no internet) ─────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://dlp:dlp@localhost:5432/dlp

# ── Redis (local Docker — no internet) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_BEFORE_PRODUCTION
JWT_EXPIRE_MINUTES=480
ADMIN_PASSWORD=Admin@SecurePass123!
VIEWER_PASSWORD=Viewer@Pass456!

# ── Local SMTP via MailHog (completely offline — no SendGrid) ──────────────────
# Emails viewable at http://localhost:8025
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=dlp-alerts@internal.local
SMTP_TO=security-team@internal.local

# ── Local Ollama LLM (Layer 10 — completely offline) ───────────────────────────
# Model is pre-downloaded by setup-offline.sh
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M

# ── HuggingFace offline mode (prevents any internet calls) ────────────────────
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# ── GLiNER model local path (pre-downloaded by setup-offline.sh) ───────────────
GLINER_MODEL_PATH=/app/models/gliner_medium
GLINER_TOKENIZER_PATH=/app/models/deberta-tokenizer

# ── Optional: Internal Slack (only if your org has Slack) ─────────────────────
# Leave blank if your org does not use Slack
SLACK_WEBHOOK_URL=
