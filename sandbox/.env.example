# Database
POSTGRES_URL=postgresql+asyncpg://dlp:dlp@localhost:5432/dlp

# Redis
REDIS_URL=redis://localhost:6379

# JWT Auth
JWT_SECRET_KEY=CHANGE_ME_BEFORE_PRODUCTION_USE_32_CHARS_MINIMUM
JWT_EXPIRE_MINUTES=480
ADMIN_PASSWORD=Admin@SecurePass123!
VIEWER_PASSWORD=Viewer@Pass456!

# Slack Alerting (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# SendGrid Email Alerting (optional)
SENDGRID_API_KEY=SG.your_key_here
ALERT_EMAIL_FROM=dlp-alerts@yourcompany.com
ALERT_EMAIL_TO=security-team@yourcompany.com

# PagerDuty (optional)
PAGERDUTY_ROUTING_KEY=your_pagerduty_routing_key